generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum RoadmapStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ModuleStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ProjectDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum UserProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  REVIEW
  COMPLETED
  ABANDONED
}

enum QuizMode {
  MANUAL
  RESUME_BASED
}

enum QuizLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum PostType {
  POST
  QUESTION
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum ApplicationStatus {
  SAVED
  APPLIED
  REVIEWING
  INTERVIEW
  OFFER
  REJECTED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String             @unique
  password          String?
  image             String?
  role              UserRole           @default(USER)
  title             String?
  bio               String?            @db.Text
  currentLevel      String?
  targetRole        String?
  location          String?
  leetcodeUsername  String?
  codeforcesHandle  String?
  xp                Int                @default(0)
  streak            Int                @default(0)
  level             Int                @default(1)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  accounts          Account[]
  sessions          Session[]
  roadmaps          Roadmap[]
  userProjects      UserProject[]
  resumes           Resume[]
  quizResults       QuizResult[]
  posts             CommunityPost[]
  comments          PostComment[]
  ownedStudyGroups  StudyGroup[]       @relation("StudyGroupOwner")
  groupMemberships  StudyGroupMember[]
  challengeEntries  ChallengeEntry[]
  applications      Application[]

  @@index([role])
  @@index([createdAt])
}

model Roadmap {
  id                String           @id @default(cuid())
  userId            String
  title             String
  careerGoal        String
  track             String           @default("general")
  currentSkillLevel String
  knownSkills       String[]
  learningPace      String
  educationLevel    String
  summary           String           @db.Text
  estimatedWeeks    Int
  status            RoadmapStatus    @default(ACTIVE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  modules           RoadmapModule[]
  milestones        RoadmapMilestone[]
  userProjects      UserProject[]

  @@index([userId, status])
  @@index([careerGoal])
  @@index([track])
}

model RoadmapModule {
  id          String       @id @default(cuid())
  roadmapId   String
  title       String
  description String       @db.Text
  weekStart   Int
  weekEnd     Int
  status      ModuleStatus @default(NOT_STARTED)
  position    Int
  roadmap     Roadmap      @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  lessons          RoadmapLesson[]
  certifications   ModuleCertification[]
  practiceProblems ModulePractice[]
  quizQuestions    QuizQuestion[]
  recommendedProjects Project[]

  @@index([roadmapId, position])
}

model RoadmapMilestone {
  id          String       @id @default(cuid())
  roadmapId   String
  title       String
  description String?      @db.Text
  dueWeek     Int
  status      ModuleStatus @default(NOT_STARTED)
  roadmap     Roadmap      @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId, dueWeek])
}

model RoadmapLesson {
  id             String    @id @default(cuid())
  moduleId       String
  title          String
  content        String    @db.Text
  estimatedMins  Int
  difficulty     ProjectDifficulty @default(BEGINNER)
  position       Int
  module         RoadmapModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  
  videos         LessonVideo[]
  articles       LessonArticle[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([moduleId, position])
}

model LessonVideo {
  id         String    @id @default(cuid())
  lessonId   String
  title      String
  youtubeUrl String
  lesson     RoadmapLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model LessonArticle {
  id         String    @id @default(cuid())
  lessonId   String
  title      String
  url        String
  source     String
  lesson     RoadmapLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model ModuleCertification {
  id              String         @id @default(cuid())
  moduleId        String
  provider        String
  courseUrl       String
  certificateName String
  module          RoadmapModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
}

model ModulePractice {
  id          String         @id @default(cuid())
  moduleId    String
  title       String
  description String         @db.Text
  difficulty  ProjectDifficulty
  module      RoadmapModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
}

model Project {
  id               String             @id @default(cuid())
  title            String
  slug             String             @unique
  summary          String             @db.Text
  description      String             @db.Text
  difficulty       ProjectDifficulty
  stack            String[]
  tracks           String[]
  estimatedHours   Int
  repoUrl          String
  workspacePath    String?
  requirements     String[]
  learningOutcomes String[]
  isFeatured       Boolean            @default(false)

  recommendedAfterModuleId String?
  recommendedAfterModule   RoadmapModule? @relation(fields: [recommendedAfterModuleId], references: [id], onDelete: SetNull)

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  userProjects     UserProject[]

  @@index([difficulty])
  @@index([isFeatured])
  @@index([tracks])
}

model UserProject {
  id            String            @id @default(cuid())
  userId        String
  projectId     String
  roadmapId     String?
  status        UserProjectStatus @default(IN_PROGRESS)
  progress      Int               @default(0)
  notes         String?           @db.Text
  startedAt     DateTime          @default(now())
  completedAt   DateTime?
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roadmap       Roadmap?          @relation(fields: [roadmapId], references: [id], onDelete: SetNull)
  sessions      ProjectSession[]

  @@unique([userId, projectId])
  @@index([userId, status])
  @@index([projectId])
}

model ProjectSession {
  id            String      @id @default(cuid())
  userProjectId String
  startedAt     DateTime    @default(now())
  endedAt       DateTime?
  statusNote    String?
  progressDelta Int         @default(0)
  userProject   UserProject @relation(fields: [userProjectId], references: [id], onDelete: Cascade)

  @@index([userProjectId, startedAt])
}

model Resume {
  id             String           @id @default(cuid())
  userId         String
  title          String
  template       String
  data           Json
  atsScore       Int              @default(0)
  grammarScore   Int              @default(0)
  keywordScore   Int              @default(0)
  isPublic       Boolean          @default(false)
  lastExportedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses       ResumeAnalysis[]
  applications   Application[]

  @@index([userId, updatedAt])
}

model ResumeAnalysis {
  id                 String   @id @default(cuid())
  resumeId           String
  atsScore           Int
  grammarScore       Int      @default(0)
  keywordScore       Int      @default(0)
  grammarFeedback    String[] @default([])
  keywordSuggestions String[] @default([])
  skillSuggestions   String[] @default([])
  summary            String   @db.Text
  rawText            String   @db.Text
  provider           String?
  model              String?
  createdAt          DateTime @default(now())
  resume             Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId, createdAt])
}

model QuizQuestion {
  id          String      @id @default(cuid())
  skill       String
  topic       String
  mode        QuizMode    @default(MANUAL)
  difficulty  QuizLevel
  prompt      String      @db.Text
  options     String[]
  correct     Int
  explanation String      @db.Text
  createdAt   DateTime    @default(now())

  modules     RoadmapModule[]

  @@index([skill, difficulty])
  @@index([mode])
}

model QuizResult {
  id             String       @id @default(cuid())
  userId         String
  skill          String
  mode           QuizMode
  score          Int
  level          QuizLevel
  totalQuestions Int
  correctAnswers Int
  feedback       String?      @db.Text
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([skill, level])
}

model CommunityPost {
  id          String         @id @default(cuid())
  userId      String
  type        PostType       @default(POST)
  title       String
  content     String         @db.Text
  tags        String[]
  upvotes     Int            @default(0)
  downvotes   Int            @default(0)
  isAnswered  Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments    PostComment[]

  @@index([type, createdAt])
  @@index([userId, createdAt])
}

model PostComment {
  id        String        @id @default(cuid())
  postId     String
  userId     String
  content    String       @db.Text
  isAccepted Boolean      @default(false)
  createdAt  DateTime     @default(now())
  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId])
}

model StudyGroup {
  id          String             @id @default(cuid())
  ownerId     String
  name        String
  description String             @db.Text
  tags        String[]
  emoji       String             @default("Study")
  createdAt   DateTime           @default(now())
  owner       User               @relation("StudyGroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     StudyGroupMember[]

  @@index([ownerId])
  @@index([createdAt])
}

model StudyGroupMember {
  id          String     @id @default(cuid())
  studyGroupId String
  userId      String
  joinedAt    DateTime   @default(now())
  studyGroup  StudyGroup @relation(fields: [studyGroupId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([studyGroupId, userId])
  @@index([userId])
}

model Challenge {
  id             String           @id @default(cuid())
  title          String
  description    String           @db.Text
  deadline       DateTime
  prize          String
  difficulty     ProjectDifficulty
  bannerColor    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  entries        ChallengeEntry[]

  @@index([deadline])
}

model ChallengeEntry {
  id          String    @id @default(cuid())
  challengeId String
  userId      String
  githubUrl   String
  description String?   @db.Text
  submittedAt DateTime  @default(now())
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId, submittedAt])
}

model Job {
  id             String          @id @default(cuid())
  title          String
  company        String
  location       String
  description    String          @db.Text
  salaryRange    String
  type           JobType
  skills         String[]
  sourceUrl      String?
  remoteFriendly Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  applications   Application[]

  @@index([type, createdAt])
  @@index([location])
}

model Application {
  id          String            @id @default(cuid())
  userId       String
  jobId        String
  resumeId     String?
  fullName     String
  email        String
  phone        String?
  coverLetter  String?          @db.Text
  attachmentUrl String?
  status       ApplicationStatus @default(APPLIED)
  appliedAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  job          Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume       Resume?          @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@unique([userId, jobId])
  @@index([userId, status])
  @@index([jobId, status])
}
